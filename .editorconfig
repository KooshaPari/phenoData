# EditorConfig: https://editorconfig.org
root = true

[*]
indent_style = tab
indent_size = 2
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{md,yml,yaml,json,toml}]
indent_size = 2

[*.rs]
indent_size = 2
max_line_length = 100

[Makefile]
indent_style = tab
